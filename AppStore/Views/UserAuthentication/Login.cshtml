@model AppStore.Models.DTO.LoginModel
@{
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión | TechStore</title>
    <link rel="stylesheet" href="~/css/login.css">
</head>
<body>

    <main class="login-page-container">
        <div class="login-card">
            <div class="login-header">
                <h1>Iniciar sesión</h1>
                <p>Bienvenido de nuevo a TechStore. Ingresa tus credenciales para continuar.</p>
            </div>

           

            <form class="login-form" asp-action="Login" method="post">
                <div class="form-group">
                    <label asp-for="Username">Usuario</label>
                    <input type="text" asp-for="Username" class="form-input form-input-error" placeholder="Tu nombre de usuario" required>
                </div>

                <div class="error-alert">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    <span asp-validation-for="Username"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Contraseña</label>
                    <input type="password" class="form-input" class="form-input form-input-error"  placeholder="••••••••" required asp-for="Password">
                </div>

                <div class="error-alert">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    <span asp-validation-for="Password"></span>
                </div>

                <div class="form-options">
                    <a href="#" class="forgot-password-link">¿Olvidaste tu contraseña?</a>
                </div>

                @if(TempData["msg"]!= null)
                {
                    <div class="error-alert">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                        @TempData["msg"]
                    </div>
                }

                <button type="submit" class="btn-primary btn-block">Ingresar</button>
            </form>

            <div class="login-footer">
                <p>¿No tienes una cuenta? <a href="#">Regístrate aquí</a></p>
            </div>
        </div>
    </main>

</body>
</html>

