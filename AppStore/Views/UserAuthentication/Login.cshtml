@model AppStore.Models.DTO.LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers  @* <-- AGREGA ESTO AQUÍ *@
@{
    Layout = null; // O tu configuración de layout
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión | TechStore</title>
    <link rel="stylesheet" href="~/css/login.css">
</head>
<body>

    <main class="login-page-container">
        <div class="login-card">
            <div class="login-header">
                <h1>Iniciar sesión</h1>
                <p>Bienvenido de nuevo a TechStore. Ingresa tus credenciales para continuar.</p>
            </div>

           

            <form class="login-form" asp-controller="UserAuthentication"  asp-action="Login" method="post">
                <div class="form-group">
                    <label>Usuario</label>
                    <input type="text" name="Username" id="Username" class="form-input" placeholder="Tu nombre de usuario" required value="@Model?.Username">
                </div>

                <div class="form-group">
                    <label>Contraseña</label>
                    <input type="password" name="Password" id="Password" class="form-input" placeholder="••••••••" required>
                </div>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="error-alert" style="display: block !important; border: 2px solid red;">
                        
                        <span>@ViewBag.ErrorMessage</span>
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <button type="submit" class="btn-primary btn-block">Ingresar</button>
            </form>

            <div class="login-footer">
                <p>¿No tienes una cuenta? <a href="#">Regístrate aquí</a></p>
            </div>
        </div>
    </main>

</body>
</html>

