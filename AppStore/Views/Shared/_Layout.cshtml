@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechStore | Minimal</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>

    <header class="navbar">
        <div class="nav-container">
            <div class="logo">TechStore.</div>
            <nav class="nav-links">
                <a href="#">Inicio</a>
                <a href="#">Catálogo</a>
                <a href="#">Ofertas</a>
            </nav>
            <div class="nav-actions">
                <button class="login-btn">Iniciar sesión</button>
                <button class="cart-btn">Carrito (0)</button>
            </div>
        </div>
    </header>

    <main class="home-container">
        @RenderBody()
    </main>
    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-column brand-column">
                <div class="logo">TechStore.</div>
                <p>Minimalismo y rendimiento en cada dispositivo que ofrecemos.</p>
            </div>

            <div class="footer-column">
                <h4>Tienda</h4>
                <a href="#">Todos los productos</a>
                <a href="#">Nuevos lanzamientos</a>
                <a href="#">Ofertas especiales</a>
            </div>

            <div class="footer-column">
                <h4>Soporte</h4>
                <a href="#">Centro de ayuda</a>
                <a href="#">Envíos y devoluciones</a>
                <a href="#">Contáctanos</a>
            </div>

            <div class="footer-column">
                <h4>Legal</h4>
                <a href="#">Términos de servicio</a>
                <a href="#">Política de privacidad</a>
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; 2026 TechStore. Todos los derechos reservados.</p>
        </div>
    </footer>
</body>
</html>