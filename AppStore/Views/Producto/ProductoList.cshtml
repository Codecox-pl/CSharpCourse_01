    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model AppStore.Models.DTO.ProductoListVm
@{
}


<div>

    <h2>Administracion de Productos</h2>

    <table>
        <tr>
        <th>Nombre</th>
        <th>Desripcion</th>
        <th>Imagen</th>
        <th>Cantidad</th>
        <th>Precio</th>
        <th>Accion</th>

        </tr>
        
        @foreach(var item in Model.ProductoList!)
        {
            <tr>
                <td>@item.NombrePro</td>
                <td>@item.Descripcion</td>
                <td><img style="height:60px;width:80px;" /></td>
                <td>@item.Cantidad</td>
                <td>@item.Precio</td>
                <td>
                    <a href="/Producto/Edit?id=@item.ProductoId">
                        Editar    
                    </a>
                    <a href="/Producto/Delete?id=@item.ProductoId" onClick="return window.confirm('Estas seguro?')">
                        Eliminar
                    </a>
                </td>
            </tr>
        }

    </table>

    <div>
        <a href="/Producto/Add">Atras</a>
    </div>

</div>
