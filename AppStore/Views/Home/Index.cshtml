@{
    Layout = "_Layout";
}
@model AppStore.Models.DTO.ProductoListVm;

<section class="hero">
    <div class="hero-content">
        <h1>Tecnología pura. Sin distracciones.</h1>
        <p>Equipos de alto rendimiento con un diseño enfocado en lo esencial.</p>
        <button class="btn-primary">Explorar Catálogo</button>
    </div>
</section>

<section class="featured-products">
    <h2>Selección Destacada</h2>

    <div class="product-grid">

        @foreach(var producto in Model.ProductoList!)
        {
            <article class="product-card">
                <img src="https://pixabay.com/es/images/download/antonio_cansino-mouse-5417888_1920.jpg" alt="@producto.NombrePro" class="product-image">
                <div class="product-info">
                    <h3>@producto.NombrePro</h3> 
                    <p class="price">@producto.Precio</p>
                    <p class="price"> @producto.CategoriasNames</p>
                    <button class="btn-outline" onclick="window.location.href='/Home/ProductoDetail?ProductoId=@producto.ProductoId'">Ver detalles</button>
                </div>
            </article>
        }

        

       
    </div>
</section>