@{
    Layout = "_Layout";
}


<section class="hero">
    <div class="hero-content">
        <h1>Tecnología pura. Sin distracciones.</h1>
        <p>Equipos de alto rendimiento con un diseño enfocado en lo esencial.</p>
        <button class="btn-primary">Explorar Catálogo</button>
    </div>
</section>

<section class="featured-products">
    <h2>Selección Destacada</h2>

    <div class="product-grid">
        <article class="product-card">
            <img src="https://placehold.co/400x400/f2f2f2/808080?text=Laptop+Pro" alt="Laptop Pro Minimal" class="product-image">
            <div class="product-info">
                <h3>Laptop Pro Minimal</h3>
                <p class="price">$1,299.00</p>
                <button class="btn-outline">Ver detalles</button>
            </div>
        </article>

        <article class="product-card">
            <img src="https://placehold.co/400x400/f2f2f2/808080?text=Auriculares" alt="Auriculares Studio" class="product-image">
            <div class="product-info">
                <h3>Auriculares Studio</h3>
                <p class="price">$249.50</p>
                <button class="btn-outline">Ver detalles</button>
            </div>
        </article>

        <article class="product-card">
            <img src="https://placehold.co/400x400/f2f2f2/808080?text=Teclado" alt="Teclado Mecánico Q1" class="product-image">
            <div class="product-info">
                <h3>Teclado Mecánico Q1</h3>
                <p class="price">$110.00</p>
                <button class="btn-outline">Ver detalles</button>
            </div>
        </article>

        <article class="product-card">
            <img src="https://placehold.co/400x400/f2f2f2/808080?text=Monitor" alt="Monitor UltraWide" class="product-image">
            <div class="product-info">
                <h3>Monitor UltraWide</h3>
                <p class="price">$450.00</p>
                <button class="btn-outline">Ver detalles</button>
            </div>
        </article>
    </div>
</section>